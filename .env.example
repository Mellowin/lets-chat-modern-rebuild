# ==========================================
# Database
# ==========================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/letschat?schema=public

# ==========================================
# Redis
# ==========================================
REDIS_URL=redis://localhost:6379

# ==========================================
# Auth
# ==========================================
BCRYPT_SALT_ROUNDS=12

# ==========================================
# JWT
# ==========================================
JWT_ACCESS_SECRET=change-me-in-production-min-32-characters-long
JWT_REFRESH_SECRET=change-me-in-production-min-32-characters-long
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ==========================================
# MinIO / S3
# ==========================================
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=letschat-uploads
S3_FORCE_PATH_STYLE=true

# ==========================================
# API
# ==========================================
PORT=3001
API_URL=http://localhost:3001

# ==========================================
# Web
# ==========================================
NEXT_PUBLIC_API_URL=http://localhost:3001
