# ==========================================
# Database
# ==========================================
# Local Docker Postgres (matches docker-compose.yml). Safe local-only credentials.
DATABASE_URL=postgresql://letschat:letschat@localhost:5432/letschat_local?schema=public

# ==========================================
# Redis
# ==========================================
REDIS_URL=redis://localhost:6379
# Optional: enables Socket.io Redis adapter for multi-instance deployments.
# If omitted, the API uses the default in-memory Socket.io adapter.
# WEBSOCKET_REDIS_URL=redis://localhost:6379

# Optional: enables Redis-backed presence store for multi-instance deployments.
# If omitted, presence state is kept in-memory (default).
# PRESENCE_REDIS_URL=redis://localhost:6379

# ==========================================
# Auth
# ==========================================
BCRYPT_SALT_ROUNDS=12

# ==========================================
# JWT
# ==========================================
JWT_ACCESS_SECRET=change-me-in-production-min-32-characters-long
JWT_REFRESH_SECRET=change-me-in-production-min-32-characters-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ==========================================
# MinIO / S3
# ==========================================
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=letschat-uploads
S3_FORCE_PATH_STYLE=true

# ==========================================
# API
# ==========================================
PORT=3001
# CORS_ORIGIN=http://localhost:3000
# For production with Vercel, set to your frontend URL:
# CORS_ORIGIN=https://your-app.vercel.app

# ==========================================
# Mail
# ==========================================
# Primary provider: console (logs link locally), resend, or smtp.
# For local development with Mailpit, use smtp and point at localhost:1025.
MAIL_PROVIDER=smtp
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=mailpit
SMTP_PASS=mailpit
SMTP_FROM=noreply@example.com

# Optional: Resend for real production email delivery.
# MAIL_PROVIDER=resend
# RESEND_API_KEY=re_xxx
# MAIL_FROM=noreply@example.com

# Optional SMTP fallback used when the primary Resend provider fails
# with a temporary error (quota, 5xx, network outage).
# MAIL_FALLBACK_PROVIDER=smtp
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# SMTP_FROM=noreply@example.com

APP_WEB_URL=http://localhost:3000

# ==========================================
# Demo mode (disabled by default)
# Enables a one-click "Try live demo" flow for recruiters/interviewers.
# Creates disposable verified demo users and isolated demo workspaces.
# DEMO_MODE_ENABLED=true
# DEMO_SESSION_TTL_HOURS=24
# DEMO_RATE_LIMIT_PER_HOUR=10

# ==========================================
# Web Push (VAPID)
# Generate keys with: pnpm --filter api push:generate-vapid-keys
# VAPID_SUBJECT must be a URL or mailto: address you control.
# ==========================================
# VAPID_PUBLIC_KEY=your-public-key
# VAPID_PRIVATE_KEY=your-private-key
# VAPID_SUBJECT=https://your-app.vercel.app
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-public-key

# ==========================================
# Web
# ==========================================
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_WS_URL=http://localhost:3001

# ==========================================
# Production verification (optional)
# ==========================================
# Reusable verified account pool. Lets verifiers skip disposable email
# registration and avoids catchmail.io quota limits.
#
# Format 1: JSON array of { email, username, password } objects.
# VERIFY_ACCOUNT_POOL_JSON=[{"email":"user1@example.com","username":"verify1","password":"..."}]
#
# Format 2: indexed email/username/password triples.
# VERIFY_ACCOUNT_1_EMAIL=user1@example.com
# VERIFY_ACCOUNT_1_USERNAME=verify1
# VERIFY_ACCOUNT_1_PASSWORD=...
# VERIFY_ACCOUNT_2_EMAIL=user2@example.com
# VERIFY_ACCOUNT_2_USERNAME=verify2
# VERIFY_ACCOUNT_2_PASSWORD=...
#
# Recommended: at least 5 reusable verified accounts for the full suite.
# Do not commit real credentials to the repository.
#
# Seed/update accounts directly in the production DB (requires DATABASE_URL):
# DATABASE_URL=... VERIFY_ACCOUNT_POOL_JSON='[...]' pnpm verify:seed-accounts
