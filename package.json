{
  "name": "lets-chat-modern-rebuild",
  "private": true,
  "version": "0.0.1",
  "description": "Modern rebuild of lets-chat — secure team collaboration platform",
  "scripts": {
    "build": "pnpm -r build",
    "build:api:prod": "pnpm --filter @lets-chat/shared build && pnpm --filter @lets-chat/database generate && pnpm --filter @lets-chat/database build && pnpm --filter api build",
    "dev": "pnpm --parallel --filter api --filter web dev",
    "dev:api": "pnpm --filter api start:dev",
    "dev:web": "pnpm --filter web dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @lets-chat/database generate",
    "db:migrate": "pnpm --filter @lets-chat/database migrate",
    "db:studio": "pnpm --filter @lets-chat/database studio",
    "db:seed": "pnpm --filter @lets-chat/database seed"
  },
  "dependencies": {
    "@types/node": "^20.14.0"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "packageManager": "pnpm@9.1.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
