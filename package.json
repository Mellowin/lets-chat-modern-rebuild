{
  "name": "lets-chat-modern-rebuild",
  "private": true,
  "version": "0.0.1",
  "description": "Modern rebuild of lets-chat — secure team collaboration platform",
  "scripts": {
    "build": "pnpm -r build",
    "build:api:prod": "pnpm --filter @lets-chat/shared build && pnpm --filter @lets-chat/database generate && pnpm --filter @lets-chat/database build && pnpm --filter api build",
    "dev": "pnpm --parallel --filter api --filter web dev",
    "dev:api": "pnpm --filter api start:dev",
    "dev:web": "pnpm --filter web dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm --filter web typecheck && pnpm --filter api typecheck",
    "test:e2e": "pnpm --filter api test:e2e",
    "db:generate": "pnpm --filter @lets-chat/database generate",
    "db:migrate": "pnpm --filter @lets-chat/database migrate",
    "db:studio": "pnpm --filter @lets-chat/database studio",
    "db:seed": "pnpm --filter @lets-chat/database seed",
    "db:local:up": "docker compose up -d postgres redis minio mailpit",
    "db:local:down": "docker compose down",
    "db:local:reset": "docker compose down -v && docker compose up -d postgres redis minio mailpit",
    "db:migrate:local": "pnpm --filter @lets-chat/database migrate:deploy",
    "db:seed:local": "node scripts/seed-local.mjs",
    "smoke:local": "node scripts/local-smoke.mjs",
    "test:local-mail-registration": "node scripts/local-mailpit-registration.mjs",
    "verify:prod:public": "node scripts/verify-production-public.mjs",
    "verify:prod:auth": "node scripts/verify-production-auth.mjs",
    "verify:prod:permissions": "node scripts/verify-production-permissions.mjs",
    "verify:prod:browser": "node scripts/verify-production-browser.mjs",
    "verify:prod:attachments": "node scripts/verify-production-attachments.mjs",
    "verify:prod:attachments-parity": "node scripts/verify-production-attachments-parity.mjs",
    "verify:prod:contacts": "node scripts/verify-production-contacts.mjs",
    "verify:prod:contacts-privacy": "node scripts/verify-production-contacts-privacy.mjs",
    "verify:prod:groups": "node scripts/verify-production-groups.mjs",
    "verify:prod:push": "node scripts/verify-production-push.mjs",
    "verify:prod:push-browser": "node scripts/verify-production-push-browser.mjs",
    "verify:prod:pwa": "node scripts/verify-production-pwa.mjs",
    "verify:prod:safety": "node scripts/verify-production-safety.mjs",
    "verify:prod:pagination": "node scripts/verify-production-pagination.mjs",
    "verify:prod:mentions": "node scripts/verify-production-mentions.mjs",
    "verify:prod:channel-scroll": "node scripts/verify-production-channel-scroll.mjs",
    "verify:prod:channel-sidebar": "node scripts/verify-production-channel-sidebar.mjs",
    "verify:prod:admin-reports": "node scripts/verify-production-admin-reports.mjs",
    "verify:prod:diagnostics": "node scripts/verify-production-diagnostics.mjs",
    "verify:prod:audit": "node scripts/verify-production-audit.mjs",
    "verify:prod:demo": "node scripts/verify-production-demo.mjs",
    "verify:prod:message-search": "node scripts/verify-production-message-search.mjs",
    "verify:prod:message-jump": "node scripts/verify-production-message-jump.mjs",
    "verify:prod:realtime": "node scripts/verify-production-realtime.mjs",
    "verify:prod:presence": "node scripts/verify-production-presence.mjs",
    "verify:prod:mobile-shell": "node scripts/verify-mobile-shell.mjs",
    "verify:prod:core": "node scripts/verify-production-suite.mjs --group core",
    "verify:prod:messaging": "node scripts/verify-production-suite.mjs --group messaging",
    "verify:prod:social": "node scripts/verify-production-suite.mjs --group social",
    "verify:prod:admin-suite": "node scripts/verify-production-suite.mjs --group admin-suite",
    "verify:prod:browser-suite": "node scripts/verify-production-suite.mjs --group browser-suite",
    "verify:prod:all": "node scripts/verify-production-suite.mjs --group all",
    "verify:prod:demo-readiness": "node scripts/verify-production-demo-readiness.mjs",
    "verify:seed-accounts": "pnpm --filter api seed:verifier-accounts"
  },
  "dependencies": {
    "@types/node": "^20.14.0"
  },
  "devDependencies": {
    "playwright": "^1.61.0",
    "socket.io-client": "^4.8.3",
    "typescript": "^5.4.5"
  },
  "packageManager": "pnpm@9.1.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
